{
  "name": "@g3mx/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "G3MX smart contracts — G3MXVault custodial escrow + fee vault.",
  "scripts": {
    "compile": "hardhat compile && pnpm sync:abi",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "verify:sepolia": "hardhat verify --network baseSepolia",
    "verify:base": "hardhat verify --network base",
    "sync:abi": "node scripts/sync-abi.mjs",
    "check:sepolia": "hardhat run scripts/check-sepolia.ts --network baseSepolia",
    "clean": "hardhat clean",
    "node": "hardhat node",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^3.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@types/node": "^22.10.5",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0",
    "typescript": "^5.6.3",
    "viem": "^2.21.0"
  }
}
