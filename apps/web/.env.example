# ──────────────────────────────────────────────────────────────
# G3MX Marketplace — environment template
# Copy to .env.local and fill in. Never commit .env.local.
# ──────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME=G3MX
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Privy (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=

# WalletConnect (used through wagmi via Privy)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Default chain for wagmi config (bsc | mainnet | polygon | arbitrum | baseSepolia)
NEXT_PUBLIC_DEFAULT_CHAIN=bsc

# Server-only
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/g3mx
TOPUP_PROVIDER_API_KEY=
TOPUP_PROVIDER_API_URL=

# ──────────────────────────────────────────────────────────────
# Server-only — never expose to the client
# ──────────────────────────────────────────────────────────────

# Supabase service-role key (Dashboard → Project Settings → API).
# Used by Next.js Route Handlers to bypass RLS for admin operations.
# DO NOT prefix with NEXT_PUBLIC_ — must stay server-side.
SUPABASE_SERVICE_ROLE_KEY=

# Privy app secret (Dashboard → API keys → "App secret"). Pairs with
# NEXT_PUBLIC_PRIVY_APP_ID to verify JWTs from client-side getAccessToken().
PRIVY_APP_SECRET=

# Comma-separated list of Privy user IDs (did:privy:...) granted admin
# access to /admin/games and the /api/admin/* routes.
# TODO: migrate to database role management.
ADMIN_PRIVY_USER_IDS=

# Anthropic API key for the GG customer-support chatbot
# (https://console.anthropic.com → API Keys). When unset, the chat widget
# returns a graceful "AI offline — email support@g3mx.xyz" message instead
# of crashing.
ANTHROPIC_API_KEY=

# Discord webhook URL for routing bug/issue reports filed via the GG chatbot.
# Create in your Discord server: Channel Settings → Integrations → Webhooks.
# When unset, GG tells the user it can't reach the team and to email support.
DISCORD_WEBHOOK_URL=
