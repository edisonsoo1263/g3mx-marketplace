{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": ["hardhat.config.ts", "scripts/**/*", "test/**/*"],
  "exclude": ["node_modules", "artifacts", "cache", "dist"]
}
