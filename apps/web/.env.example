# ──────────────────────────────────────────────────────────────
# G3MX Marketplace — environment template
# Copy to .env.local and fill in. Never commit .env.local.
# ──────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME=G3MX
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Privy (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=

# WalletConnect (used through wagmi via Privy)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Default chain for wagmi config (base | arbitrum | bsc)
NEXT_PUBLIC_DEFAULT_CHAIN=base

# Set to 1 to swap Base mainnet for Base Sepolia (testnet) across wagmi,
# Privy, and the block-explorer links. Leave empty/unset in production.
# Per-environment override: set 1 on Vercel preview deployments only.
NEXT_PUBLIC_USE_TESTNET=

# Firebase (https://console.firebase.google.com → Project settings → General)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Server-only
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/g3mx
TOPUP_PROVIDER_API_KEY=
TOPUP_PROVIDER_API_URL=
