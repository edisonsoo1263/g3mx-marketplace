# ─────────────────────────────────────────────────────────────
# G3MX Contracts — Hardhat environment
# Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Private key of the deployer wallet. Exported from MetaMask.
# Account details → ⋮ menu → Account details → Show private key.
# This wallet pays for gas and becomes the vault `owner`.
# DO NOT use a key that holds real funds. Use a fresh testnet wallet.
DEPLOYER_PRIVATE_KEY=

# Base Sepolia testnet RPC. Public default works for low volume;
# for production swap in Alchemy/Infura/QuickNode.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base mainnet RPC (Phase 2+, leave empty for now).
BASE_RPC_URL=https://mainnet.base.org

# Basescan API key for `hardhat verify` (free at basescan.org/myapikey).
# Optional for testnet; required to publish contract source to basescan.
BASESCAN_API_KEY=

# Constructor argument: ERC20 token address the vault escrows.
# Base Sepolia USDC (Circle): 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base mainnet USDC (Circle): 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
VAULT_TOKEN_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
